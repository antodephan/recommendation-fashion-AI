# ============================================================
# AI Fashion Recommendation System — Environment Variables
# Copy this file to `.env` and fill in real values.
# ============================================================

# -------- General --------
PROJECT_NAME=AI Fashion Recommendation System
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=INFO

# -------- Frontend --------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=Couture AI

# -------- Backend / FastAPI --------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1
API_V1_PREFIX=/api/v1

# -------- Legacy fashion dataset (styles.csv + images) --------
# Docker: paths below are set in docker-compose.yml (/app/legacy)
FASHION_LEGACY_DIR=../Fashion-Recomendation-AI-ChatBot
FASHION_CSV_PATH=../Fashion-Recomendation-AI-ChatBot/data/styles.csv
FASHION_IMAGES_DIR=../Fashion-Recomendation-AI-ChatBot/data/images
CATALOG_IMPORT_LIMIT=3000
CATALOG_AUTO_IMPORT=false

# -------- RapidAPI H&M --------
RAPIDAPI_KEY=
RAPIDAPI_HM_HOST=apidojo-hm-hennes-mauritz-v1.p.rapidapi.com
HM_REGION=vn
HM_CATALOG_IMPORT_LIMIT=2000
HM_CATALOG_SECTIONS=ladies,men
HM_CATALOG_AUTO_IMPORT=true
HM_TRENDS_SYNC_INTERVAL_HOURS=72
HM_SCHEDULER_ENABLED=true

# -------- Security --------
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=48
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false                  # set to true in production over HTTPS

# -------- PostgreSQL --------
POSTGRES_USER=fashion
POSTGRES_PASSWORD=fashion
POSTGRES_DB=fashion
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://fashion:fashion@postgres:5432/fashion

# -------- Redis --------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# -------- Qdrant --------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_OUTFITS=outfits
QDRANT_COLLECTION_PRODUCTS=products
QDRANT_COLLECTION_USERS=user_profiles
QDRANT_COLLECTION_CHATS=chat_memory
QDRANT_COLLECTION_KB=fashion_kb

# -------- OpenAI --------
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-5.4-mini

# -------- OAuth: Google --------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# -------- OAuth: Facebook --------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/facebook/callback

# -------- Email (SMTP) --------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@couture.ai
SMTP_FROM_NAME=Couture AI

# -------- Weather API (OpenWeather) --------
OPENWEATHER_API_KEY=

# -------- Sentry (optional) --------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# -------- Admin bootstrap --------
SUPERADMIN_EMAIL=admin@couture.ai
SUPERADMIN_PASSWORD=changeme123!
